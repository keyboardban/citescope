# Copy this file to ".env" and fill in your keys.
# These are read at runtime via python-dotenv. Never commit the real .env.

# Google AI Studio / Gemini API key  -> https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Apify API token  -> https://console.apify.com/account/integrations
APIFY_TOKEN=

# ---- optional overrides (sensible defaults are used if unset) ----
# APIFY_SERP_ACTOR=apify/google-search-scraper
# APIFY_SCRAPER_ACTOR=apify/website-content-crawler
# GEMINI_DEFAULT_MODEL=gemini-2.5-flash
# GEMINI_EMBED_MODEL=text-embedding-004
